# Django Settings
DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use sqlite3 for development, postgresql for production)
DB_ENGINE=django.db.backends.sqlite3

# PostgreSQL (uncomment and fill for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=startup_site
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# Email Settings (Gmail SMTP)
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://myaccount.google.com/security → App passwords
# 3. Generate a new app password for "Mail"
# 4. Use that 16-character password below
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=your-gmail@gmail.com